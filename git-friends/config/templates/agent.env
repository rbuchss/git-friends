################################################################################
# Agent environment configuration
#
# Configures HTTPS token-based git authentication for agent loops, CI/CD,
# or any non-SSH context. Each agent should get its own scoped token.
#
# Install with:
#   git setup-config agent-env [target-path]
#   # or manually: cp ~/.git-friends/config/templates/agent.env /path/to/.env
#
# Token isolation: use fine-grained GitHub PATs with minimal permissions
# per repo/agent. Never use a single global token across agents.
################################################################################

# Scoped GitHub personal access token (fine-grained recommended).
# Grant only the permissions this agent needs, typically:
#   - Contents: Read & Write (for the specific repositories)
#   - Pull requests: Read & Write (if the agent creates PRs)
GITHUB_TOKEN=ghp_your_scoped_token_here

# Git config overrides: inject credential helper without modifying files.
# These are process-scoped and take highest precedence over file-based config.
#
# To add more overrides, increment GIT_CONFIG_COUNT and add KEY/VALUE pairs.
GIT_CONFIG_COUNT=1
GIT_CONFIG_KEY_0=credential.https://github.com.helper
GIT_CONFIG_VALUE_0=${HOME}/.git-friends/bin/credential-helper
